                    <SerializationItem>
                        <IsListValue>false</IsListValue>
                        <Name>Script</Name>
                        <Value xsi:type="xsd:string">Random random = new Random();

// Очищаем таблицу, если нужно заполнить заново
interationCountTable.Clear();

// Добавляем столбцы, если их еще нет
if (interationCountTable.Columns.Count == 0)
{
    interationCountTable.Columns.Add("Index", typeof(int));
    interationCountTable.Columns.Add("RandomNumber", typeof(int));
}

// Заполняем таблицу
for (int i = 0; i &lt; iterationCount; i++)
{
    System.Data.DataRow row = interationCountTable.NewRow();
    row["Index"] = i + 1;
    row["RandomNumber"] = random.Next();
    interationCountTable.Rows.Add(row);
}</Value>
