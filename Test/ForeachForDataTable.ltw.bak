                    <SerializationItem>
                        <IsListValue>false</IsListValue>
                        <Name>Script</Name>
                        <Value xsi:type="xsd:string">if(!string.IsNullOrEmpty(OrchObject))
{
    avalibleRateLimiter = Convert.ToInt32(LTools.Enterprise.Elements.WFGetAsset.AssetGet(_Workflow,OrchObject));
}
else if (RepeatInTimes is not null)
{
    avalibleRateLimiter=RepeatInTimes.Value;
}
else if (!string.IsNullOrEmpty(SequenceOrchObject))
{
    avalibleRateLimiter = Convert.ToInt32(LTools.Enterprise.Elements.WFGetAsset.AssetGet(_Workflow,SequenceOrchObject)) ;
}
else
{
    avalibleRateLimiter=SequenceRepeatInTimes.Value;
}</Value>
